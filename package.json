{
  "name": "dxon-task-tracker",
  "version": "1.0.0",
  "description": "Daily task tracker with epics, editable template and calendar view",
  "main": "electron/main.js",
  "author": "Joao Dxon",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.dxon.tasktracker",
    "productName": "Task Tracker",
    "files": [
      "electron/**/*",
      "src/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "TaskTracker-portable-${version}.exe",
      "unpackDirName": "TaskTracker",
      "splashImage": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Task Tracker"
    }
  }
}
